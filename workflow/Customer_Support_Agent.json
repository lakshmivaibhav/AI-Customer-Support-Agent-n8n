    {
      "parameters": {
        "jsCode": "const input = $('When chat message received').item.json.chatInput\n  .toLowerCase()\n  .trim();\n\nlet category = \"\";\n\nif (input.includes(\"account\") || input.includes(\"acc\")) {\n  category = \"Account\";\n}\n\nelse if (\n  input.includes(\"billing\") ||\n  input.includes(\"bill\") ||\n  input.includes(\"payment\")\n) {\n  category = \"Billing\";\n}\n\nelse if (\n  input.includes(\"subscription\") ||\n  input.includes(\"sub\")\n) {\n  category = \"Subscription\";\n}\n\nelse if (\n  input.includes(\"technical\") ||\n  input.includes(\"tech\") ||\n  input.includes(\"otp\") ||\n  input.includes(\"login\")\n) {\n  category = \"Technical\";\n}\n\nelse if (input.includes(\"general\")) {\n  category = \"General\";\n}\n\nreturn [{\n  json: {\n    category\n  }\n}];"
      },
